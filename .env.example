PORT=4000

# SMTP / Email settings
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Booking and contact recipient emails
BOOKING_RECIPIENT_EMAIL=info@sonsekcleaning.com
CONTACT_RECIPIENT_EMAIL=support@sonsekcleaning.com

# Paystack public key (test or live)
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# Optional: CORS allowed origin (frontend URL)
ALLOWED_ORIGIN=http://localhost:4000

